# ─────────────────────────────────────────────────────────────────────────────
# Akıllı Aile Organizatörü — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# .env hiçbir zaman Git'e eklenmez (.gitignore'da)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Project URL
# Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anon Key (PUBLIC — frontend için güvenli)
# Supabase Dashboard → Settings → API → Project API Keys → anon/public
# NOT: service_role key ASLA buraya eklenmiyor!
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE

# Uygulama Adı
VITE_APP_NAME=Akıllı Aile Organizatörü

# GitHub Pages Repo Adı (vite.config.ts base ile aynı olmalı)
VITE_REPO_BASE_PATH=/aile-organizator/
